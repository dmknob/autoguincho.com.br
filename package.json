    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.1",
    "fast-geoip": "^1.1.88",
    "helmet": "^8.1.0",
    "marked": "^17.0.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
