# .env Example - Auto Guincho V2
PORT=3001
CORS_ORIGIN=http://localhost:3001
BASE_URL=https://autoguincho.com.br
NODE_ENV=development
#NODE_ENV=production

# Database config
DB_FILE=data/autoguincho.db

# Analytics & LGPD Compliance
# Gere um hash SHA-256 aleatório para o Salt
ANALYTICS_SALT=substituir_por_hash_aleatorio

# Features toggles / Rules
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=10

# Caching Rules (in seconds)
CACHE_TTL_REGIONAL=86400

# Parâmetros de Contato
WHATSAPP_CONTACT=55XXXXXXXXXXX
GTAG_ID=G-XXXXXXX

# Admin Auth
ADMIN_PASSWORD=substituir_por_senha_segura

# Session
SESSION_SECRET=substituir_por_hash_aleatorio
