<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-50">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Auto Guincho Admin</title>
  <link rel="stylesheet" href="/css/output.css">
</head>

<body class="h-full flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="w-full max-w-md space-y-8 bg-white p-8 rounded-xl shadow-lg">
    <div>
      <h2 class="mt-6 text-center text-3xl font-bold tracking-tight text-gray-900">Acesso Restrito</h2>
      <p class="mt-2 text-center text-sm text-gray-600">Backoffice do Auto Guincho V2</p>
    </div>
    <form class="mt-8 space-y-6" action="/admin/login" method="POST">
      <% if (error) { %>
        <div class="bg-red-50 text-red-700 p-3 rounded-md text-sm text-center font-medium">
          <%= error %>
        </div>
        <% } %>
          <div class="rounded-md shadow-sm -space-y-px">
            <div>
              <label for="password" class="sr-only">Senha de Acesso</label>
              <input id="password" name="password" type="text" required
                class="relative block w-full rounded-md border-0 py-3 px-3 text-gray-900 ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:z-10 focus:ring-2 focus:ring-inset focus:ring-gray-800 sm:text-sm sm:leading-6"
                placeholder="Senha do Administrador">
            </div>
          </div>

          <div>
            <button type="submit"
              class="group relative flex w-full justify-center rounded-md bg-gray-800 px-3 py-3 text-sm font-semibold text-white hover:bg-gray-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-600">
              Acessar Painel
            </button>
          </div>
    </form>
  </div>
</body>

</html>