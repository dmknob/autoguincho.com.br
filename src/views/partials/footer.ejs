<!-- Global Scripts (e.g. tracking helper) -->
<script>
    async function trackClick(type, label, path, entityId = null) {
        try {
            await fetch('/api/analytics/event', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    event_type: type,
                    event_label: label,
                    page_path: path,
                    entity_type: 'listing',
                    entity_id: entityId
                })
            });
        } catch(e) { console.error('Tracking ignorado:', e); }
    }
</script>
