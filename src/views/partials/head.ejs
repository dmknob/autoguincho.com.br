<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= locals.title || 'Auto Guincho - Socorro Automotivo' %></title>
<meta name="description" content="<%= locals.description || 'Encontre guinchos, muncks e mecânica rápida perto de você. Sem intermediários. Fale direto com o motorista.' %>">

<!-- SEO: Canonicals e OG -->
<% if (locals.BASE_URL) { %>
<link rel="canonical" href="<%= BASE_URL %><%= locals.path || '' %>">
<meta property="og:title" content="<%= locals.title || 'Auto Guincho' %>">
<meta property="og:description" content="<%= locals.description || '' %>">
<meta property="og:image" content="<%= BASE_URL %>/images/og-default.webp">
<meta property="og:url" content="<%= BASE_URL %><%= locals.path || '' %>">
<meta name="twitter:card" content="summary_large_image">
<% } %>

<!-- Otimização Fontes & CSS -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&display=swap">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&display=swap" media="print" onload="this.media='all'">
<noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&display=swap">
</noscript>

<% if (locals.inlineCSS) { %>
    <style><%- inlineCSS %></style>
<% } else { %>
    <link rel="stylesheet" href="/css/output.css" fetchpriority="high">
<% } %>
<style>
    .bg-navy { background-color: #050b14; }
    .text-gold { color: #d4af37; border-color: #d4af37; }
    .bg-gold { background-color: #d4af37; }
    .text-ivory { color: #f8f9fa; }
    
    /* Markdown Styles */
    .markdown-body h1, .markdown-body h2 { font-weight: bold; color: #f8f9fa; margin-top: 1.5rem; margin-bottom: 1rem; border-bottom: 1px solid #1f2937; padding-bottom: 0.5rem; }
    .markdown-body h1 { font-size: 1.75rem; }
    .markdown-body h2 { font-size: 1.5rem; }
    .markdown-body p { margin-bottom: 1rem; line-height: 1.6; }
    .markdown-body strong { color: #d4af37; }

    /* CLS Stabilizers */
    .grid-stable { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; min-height: 400px; content-visibility: auto; contain-intrinsic-size: 400px; }
</style>


