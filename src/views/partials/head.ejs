<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title ? title : 'Auto Guincho' %></title>
    <meta name="description" content="<%= locals.description ? description : 'Encontre guinchos rapidamente e sem intermediários na sua região.' %>">
    
    <!-- Open Graph SEO -->
    <meta property="og:title" content="<%= locals.title ? title : 'Auto Guincho' %>">
    <meta property="og:description" content="<%= locals.description ? description : 'Encontre guinchos rapidamente e sem intermediários na sua região.' %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://autoguincho.com.br<%= locals.currentPath || '' %>">
    <meta property="og:image" content="https://autoguincho.com.br/img/og-image.jpg">
    <link rel="canonical" href="https://autoguincho.com.br<%= locals.currentPath || '' %>">
    
    <!-- Tailwind CSS v4 Output -->
    <link href="/css/output.css" rel="stylesheet">
    
    <!-- Favicon & PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0a1628">
    <link rel="apple-touch-icon" href="/favicon.svg">

    <!-- Service Worker Registration -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW Reg Failed:', err));
        });
      }
    </script>

    <!-- Schema.org Base (if present) -->
    <%- locals.jsonLd ? jsonLd : '' %>
</head>
<body class="bg-navy text-ivory font-sans min-h-screen flex flex-col">
