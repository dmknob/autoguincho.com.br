<header class="bg-navy/90 backdrop-blur sticky top-0 z-50 shadow-sm border-b border-steel">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <div class="flex-shrink-0 flex items-center">
                <a href="/" class="text-2xl font-black font-display text-gold tracking-tight flex items-center gap-2">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    Auto Guincho
                </a>
            </div>
            <div class="flex items-center gap-4">
                <nav class="hidden md:flex space-x-6 mr-2">
                    <a href="/estados" class="text-slate-300 hover:text-gold font-medium transition-colors">Locais Atendidos</a>
                </nav>
                <a href="/quero-ser-parceiro" class="hidden md:inline-flex items-center justify-center px-4 py-2 border border-slate-custom rounded-md shadow-sm text-sm font-medium text-gold bg-steel hover:bg-slate-custom transition-colors">
                    Cadastrar Guincho
                </a>
                
                <!-- Mobile menu button -->
                <button type="button" class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-slate-300 hover:text-gold hover:bg-steel focus:outline-none" aria-controls="mobile-menu" aria-expanded="false" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
                    <span class="sr-only">Abrir menu</span>
                    <svg class="block h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile menu, show/hide based on menu state. -->
    <div class="hidden md:hidden border-t border-steel bg-navy shadow-inner" id="mobile-menu">
        <div class="px-4 pt-2 pb-4 space-y-2 sm:px-3 text-center flex flex-col">
            <a href="/estados" class="block px-3 py-3 rounded-md text-base font-medium text-slate-300 hover:text-gold hover:bg-steel transition-colors">Locais Atendidos</a>
            <a href="/quero-ser-parceiro" class="block px-3 py-3 rounded-md text-base font-bold text-navy bg-gold border border-slate-custom transition-colors tracking-wide">Cadastrar Guincho</a>
        </div>
    </div>
</header>
