<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('../partials/head') %>
    
    <!-- SEO: JSON-LD @graph (Padrão Corpo Digital) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "<%= BASE_URL %>/#website",
          "url": "<%= BASE_URL %>",
          "name": "Auto Guincho",
          "description": "Socorro Automotivo Próximo a Você",
          "publisher": { "@id": "<%= BASE_URL %>/#organization" }
        },
        {
          "@type": "Organization",
          "@id": "<%= BASE_URL %>/#organization",
          "name": "Auto Guincho",
          "url": "<%= BASE_URL %>",
          "logo": {
            "@type": "ImageObject",
            "url": "<%= BASE_URL %>/images/logo.png"
          }
        }
      ]
    }
    </script>
</head>
<body class="bg-navy font-sans text-ivory min-h-screen flex flex-col">

<%- include('../partials/header') %>

<main class="flex-grow flex flex-col items-center justify-center p-6 text-center">
    <div class="max-w-3xl w-full">
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-4 mt-10 leading-tight min-h-[1.2em]">
            <span class="text-gold">Socorro perto de você.</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 mb-10 font-medium">
            Ecossistema completo de serviços leves e pesados.
        </p>
        
        <div class="bg-gray-900 border border-gray-800 p-8 rounded-2xl shadow-2xl relative">
            <form id="search-form" class="flex flex-col gap-6" onsubmit="event.preventDefault(); executeCitySearch();">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="text-left w-full">
                        <label for="category-select" class="block text-xs font-bold text-[#a09080] uppercase tracking-wider mb-2 ml-1">Escolha o tipo de serviço</label>
                        <select id="category-select" class="w-full bg-gray-800 border items-center border-gray-700 text-white rounded-xl px-4 py-4 focus:ring-2 focus:ring-gold focus:outline-none appearance-none cursor-pointer">
                            <% allCategories.forEach(cat => { %>
                                <option value="<%= cat.slug %>" <%= cat.slug === 'guincho-plataforma' ? 'selected' : '' %>><%= cat.name %></option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="text-left w-full relative">
                        <label for="city-input" class="block text-xs font-bold text-[#a09080] uppercase tracking-wider mb-2 ml-1">Selecione a cidade</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            </div>
                            <input type="text" id="city-input" required autocomplete="off" placeholder="Ex: São Paulo, Porto Alegre..." class="w-full bg-gray-800 border items-center border-gray-700 text-white rounded-xl pl-12 pr-4 py-4 focus:ring-2 focus:ring-gold focus:outline-none focus:border-transparent">
                        </div>
                        
                        <!-- Autocomplete Dropdown -->
                        <ul id="autocomplete-list" class="absolute z-50 w-full bg-gray-800 border border-t-0 border-gray-700 rounded-b-xl shadow-2xl mt-1 hidden max-h-60 overflow-y-auto text-left">
                            <!-- Itens vão aqui via JS -->
                        </ul>
                    </div>
                </div>

                <div class="hidden">
                    <input type="hidden" id="selected-uf" value="">
                    <input type="hidden" id="selected-city-slug" value="">
                </div>

                <button type="button" onclick="executeCitySearch()" class="w-full bg-gold hover:bg-yellow-500 text-black font-black text-xl px-8 py-5 rounded-xl transition-all shadow-[0_0_20px_rgba(212,175,55,0.3)] hover:scale-[1.01] active:scale-95">
                    ENCONTRAR AGORA
                </button>
            </form>
            <p id="geo-status" class="mt-4 text-sm text-red-400 hidden"></p>
        </div>

        <!-- CTA Parceiro -->
        <div class="mt-12 flex flex-col items-center gap-4">
            <a href="/seja-parceiro" class="inline-flex items-center gap-2 text-gold hover:text-white border border-gold/30 hover:border-gold px-8 py-3 rounded-xl transition-all text-lg font-black bg-gold/10 hover:bg-gold/20 shadow-lg shadow-gold/5">
                VER PLANOS E VANTAGENS
            </a>
            <a href="https://wa.me/5551993668728?text=Olá, gostaria de cadastrar minha empresa gratuitamente no portal Auto Guincho." target="_blank" class="inline-flex items-center gap-2 text-[#a09080] hover:text-gray-300 transition-all text-sm font-bold">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                ou cadastrar minha empresa gratuitamente agora
            </a>
        </div>

    </div>
</main>

<%- include('../partials/footer') %>

<script>
    const cityInput = document.getElementById('city-input');
    const autocompleteList = document.getElementById('autocomplete-list');
    const selectedUf = document.getElementById('selected-uf');
    const selectedCitySlug = document.getElementById('selected-city-slug');
    let debounceTimer;

    // Listener de digitação com Debounce
    cityInput.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        const query = this.value.trim();
        
        // Limpar seleção anterior
        selectedUf.value = "";
        selectedCitySlug.value = "";
        
        if (query.length < 2) {
            autocompleteList.innerHTML = '';
            autocompleteList.classList.add('hidden');
            return;
        }

        debounceTimer = setTimeout(async () => {
            try {
                const slug = query.normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s+/g, '-').toLowerCase();
                const response = await fetch(`/api/cities/search?q=${slug}`);
                const data = await response.json();
                
                autocompleteList.innerHTML = '';
                
                if (data.success && data.cities.length > 0) {
                    data.cities.forEach(city => {
                        const li = document.createElement('li');
                        li.className = "px-4 py-3 hover:bg-gray-700 cursor-pointer border-b border-gray-700 last:border-0 text-white flex justify-between";
                        li.innerHTML = `<span>${city.name}</span> <span class="text-gray-400 font-bold ml-2">${city.state_uf.toUpperCase()}</span>`;
                        
                        li.addEventListener('click', () => {
                            cityInput.value = `${city.name} - ${city.state_uf.toUpperCase()}`;
                            selectedUf.value = city.state_uf.toLowerCase();
                            selectedCitySlug.value = city.slug;
                            autocompleteList.innerHTML = '';
                            autocompleteList.classList.add('hidden');
                        });
                        
                        autocompleteList.appendChild(li);
                    });
                    autocompleteList.classList.remove('hidden');
                } else {
                    autocompleteList.innerHTML = '<li class="px-4 py-3 text-gray-500">Nenhuma cidade encontrada</li>';
                    autocompleteList.classList.remove('hidden');
                }
            } catch (err) {
                console.error("Erro na busca:", err);
            }
        }, 300);
    });

    document.addEventListener('click', function(e) {
        if (e.target !== cityInput && e.target !== autocompleteList) {
            autocompleteList.classList.add('hidden');
        }
    });

    async function executeCitySearch() {
        const cat = document.getElementById('category-select').value;
        const status = document.getElementById('geo-status');
        
        const uf = selectedUf.value;
        const slug = selectedCitySlug.value;
        
        if (!slug || !uf) {
            status.textContent = "Por favor, selecione uma cidade na lista para prosseguir.";
            status.classList.remove("hidden");
            status.classList.add("text-red-400");
            return;
        }

        // Registrar Evento de Pesquisa
        try {
            await fetch('/api/system/interaction', { 
                method: 'POST', 
                headers: {'Content-Type': 'application/json'}, 
                body: JSON.stringify({ 
                    event_type: 'search', 
                    event_label: cityInput.value, 
                    page_path: `/${cat}/${uf}/${slug}`, 
                    entity_type: 'city' 
                }),
                keepalive: true
            });
        } catch(e) {}
        
        // Roteador SSG Direto com delay microscópico para garantir disparo da request no Safari/Chrome
        setTimeout(() => {
            window.location.href = `/${cat}/${uf}/${slug}`;
        }, 50);
    }
</script>

</body>
</html>
