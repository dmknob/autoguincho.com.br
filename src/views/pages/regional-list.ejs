<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 flex-grow">
    <div class="mb-8 border-b border-slate-custom pb-5">
        <h1 class="text-3xl md:text-4xl font-extrabold font-display text-ivory">
            Guinchos em <span class="text-gold"><%= city.name %></span>
        </h1>
        <p class="mt-2 text-slate-300 text-lg">
            Encontramos <%= listings.length %> prestadores ativos na região.
        </p>
    </div>

    <% if(listings.length === 0) { %>
        <div class="text-center py-20 bg-steel rounded-2xl shadow-lg border border-slate-custom">
            <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="mt-2 text-sm font-medium text-ivory">Nenhum guincho encontrado</h3>
            <p class="mt-1 text-sm text-slate-400">Seja o primeiro parceiro nesta cidade!</p>
            <div class="mt-6">
                <a href="/quero-ser-parceiro" class="inline-flex items-center px-4 py-2 border shadow-sm text-sm font-medium rounded-md text-navy bg-gold hover:bg-[#b0923d] border-transparent transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gold focus:ring-offset-steel">
                    Cadastrar Meu Negócio
                </a>
            </div>
        </div>

        <% if(locals.popularCities && popularCities.length > 0) { %>
            <div class="mt-12 text-center border-t border-slate-custom pt-10">
                <h3 class="text-xl font-bold font-display text-ivory mb-6">Guinchos disponíveis próximos a você:</h3>
                <div class="flex flex-wrap justify-center gap-3">
                    <% popularCities.forEach(c => { %>
                        <a href="/<%= c.uf.toLowerCase() %>/<%= c.slug %>" class="px-5 py-3 rounded-full bg-steel border border-slate-custom text-slate-300 hover:text-gold hover:border-gold transition-colors flex items-center gap-2 shadow-lg">
                            <span class="font-semibold"><%= c.name %>, <%= c.uf %></span>
                            <span class="bg-navy text-gold py-0.5 px-2 rounded-full text-xs font-bold"><%= c.provider_count %> prestadores</span>
                        </a>
                    <% }) %>
                </div>
            </div>
        <% } %>
    <% } else { %>
        <div class="grid gap-6 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
            <% listings.forEach(function(l) { %>
                <!-- INÍCIO DO CARD -->
                <div class="bg-steel rounded-2xl shadow-lg border <%= l.is_featured ? 'border-gold ring-1 ring-gold shadow-gold/10' : 'border-slate-custom hover:border-slate-400' %> overflow-hidden flex flex-col transition-all hover:-translate-y-1">
                    
                    <% if(l.is_featured) { %>
                        <div class="bg-gold text-navy text-xs font-bold uppercase tracking-wider text-center py-1">
                            Destaque
                        </div>
                    <% } %>

                    <!-- Galeria 3 Fotos -->
                    <div class="grid grid-cols-3 h-32 md:h-40 bg-navy">
                        <% if(l.images && l.images.length >= 3) { %>
                            <% l.images.slice(0,3).forEach(img => { %>
                                <div class="w-full h-full border-r last:border-r-0 border-steel">
                                    <img src="<%= img.image_url %>" alt="Foto Guincho" class="w-full h-full object-cover" loading="lazy" onerror="this.style.opacity='0';">
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-span-3 flex items-center justify-center text-slate-500 text-sm">Sem fotos</div>
                        <% } %>
                    </div>

                    <div class="p-5 flex-grow flex flex-col">
                        <h2 class="text-xl font-bold font-display text-ivory truncate">
                            <%= l.company_name %>
                        </h2>
                        
                        <% if (l.distance) { %>
                            <p class="text-sm text-green-400 font-medium mt-1 inline-flex items-center gap-1">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
                                Aprox. <%= l.distance.toFixed(1) %> km de você
                            </p>
                        <% } %>

                        <!-- Tags (Pílulas) -->
                        <div class="mt-4 flex flex-wrap gap-2 mb-4">
                            <% if (l.tags && l.tags.length > 0) { %>
                                <% l.tags.forEach(t => { %>
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-navy text-slate-300 border border-slate-custom">
                                        <%= t.name %>
                                    </span>
                                <% }) %>
                            <% } %>
                        </div>

                        <!-- Footer do Card CTA -->
                        <div class="mt-auto pt-4 border-t border-slate-custom grid grid-cols-2 gap-3">
                            <a href="/<%= city.uf.toLowerCase() %>/<%= city.slug %>/<%= l.slug %>" class="flex justify-center items-center py-2 px-4 border border-slate-custom rounded-md shadow-sm text-sm font-medium text-slate-300 bg-steel hover:bg-slate-custom transition-colors">
                                Ver Perfil
                            </a>
                            <a href="https://wa.me/<%= l.whatsapp_number %>" target="_blank" onclick="trackClick('cta_click', 'whatsapp', window.location.pathname, '<%= l.id %>')" class="flex justify-center items-center gap-1 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 transition-colors">
                                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                                Chamar
                            </a>
                        </div>
                    </div>
                </div>
                <!-- FIM DO CARD -->
            <% }); %>
        </div>
    <% } %>
</main>

<%- include('../partials/footer') %>
