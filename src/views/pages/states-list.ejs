<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 flex-grow">
    <div class="mb-8 border-b border-slate-custom pb-5 text-center">
        <h1 class="text-3xl md:text-4xl font-extrabold font-display text-ivory">
            Estados Atendidos
        </h1>
        <p class="mt-2 text-slate-300 text-lg">
            Selecione seu estado para encontrar os melhores profissionais de socorro automotivo.
        </p>
    </div>

    <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        <% states.forEach(function(state) { %>
            <a href="/<%= state.uf.toLowerCase() %>" class="bg-steel rounded-2xl shadow-lg border border-slate-custom hover:border-gold hover:shadow-gold/10 p-6 flex flex-col items-center justify-center transition-all hover:-translate-y-1 group">
                <h2 class="text-2xl font-bold font-display text-ivory group-hover:text-gold transition-colors">
                    <%= state.name %>
                </h2>
                <div class="mt-2 flex items-center justify-center gap-2">
                    <span class="text-xs uppercase font-bold text-slate-400 bg-navy px-2 py-1 rounded-md border border-slate-custom group-hover:border-slate-500 transition-colors">
                        <%= state.uf %>
                    </span>
                    <span class="text-sm text-slate-400">
                        <%= state.city_count %> cidades cadastradas
                    </span>
                </div>
            </a>
        <% }); %>
    </div>
</main>

<%- include('../partials/footer') %>
