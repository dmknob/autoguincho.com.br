<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= listing.company_name %> em <%= city.name %> | Auto Guincho</title>
    <meta name="description" content="Contato direto via WhatsApp para <%= listing.company_name %>. Confira as especialidades.">
    <!-- Tailwind CSS v4 Output -->
    <link href="/css/output.css" rel="stylesheet">
    <style>
        body {
            background-color: #0d0d0d;
            color: #ffffff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        .hero-bg {
            /* Fallback to dark fade if no primary image */
            background: linear-gradient(to bottom, rgba(13,13,13,0.3) 0%, rgba(13,13,13,1) 100%), 
                        url('<%= listing.images && listing.images.length > 0 ? listing.images[0].image_url : "" %>') no-repeat center center;
            background-size: cover;
        }
        .glass-btn {
            background: rgba(255, 255, 255, 0.95);
            color: #111;
        }
    </style>
</head>
<body class="antialiased selection:bg-gold selection:text-navy">

    <!-- Hero Section -->
    <section class="relative min-h-[85vh] flex flex-col items-center justify-center hero-bg text-center px-4">
        <!-- Floating Back Button -->
        <a href="/<%= city.uf.toLowerCase() %>/<%= city.slug %>" class="absolute top-6 left-6 text-slate-300 hover:text-ivory flex items-center gap-2 text-sm font-medium transition-colors font-display tracking-wide uppercase">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Voltar para lista
        </a>

        <% if(listing.is_verified) { %>
            <div class="mb-6 bg-steel/60 backdrop-blur border border-slate-custom text-gold text-xs font-bold px-4 py-2 rounded-full flex items-center gap-2 shadow-2xl">
                <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                PARCEIRO VERIFICADO
            </div>
        <% } %>

        <h1 class="text-5xl md:text-7xl font-extrabold font-display tracking-tight mb-4 uppercase drop-shadow-2xl text-ivory">
            <%= listing.company_name %>
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 mb-12 drop-shadow-md font-serif italic">
            Serviço Profissional em <%= city.name %> e região
        </p>

        <div class="flex flex-col sm:flex-row gap-4 w-full max-w-lg mx-auto">
            <% if(listing.phone_number) { %>
                <a href="tel:+<%= listing.phone_number %>" onclick="trackClick('cta_click', 'telefone_perfil', window.location.pathname, '<%= listing.id %>')" class="glass-btn flex-1 flex justify-center items-center py-4 px-6 rounded-xl shadow-lg font-bold transition-transform hover:scale-105 border border-slate-custom !bg-steel !text-slate-300 hover:!bg-slate-custom">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    LIGAR AGORA
                </a>
            <% } %>
            <a href="https://wa.me/<%= listing.whatsapp_number %>" onclick="trackClick('cta_click', 'whatsapp_perfil', window.location.pathname, '<%= listing.id %>')" target="_blank" class="bg-gold text-navy flex-1 flex justify-center items-center py-4 px-6 rounded-xl shadow-lg font-bold transition-transform hover:scale-105 hover:bg-[#b0923d]">
                <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 0C5.383 0 0 5.383 0 12.031c0 2.124.551 4.195 1.597 6.014L.199 23.19l5.309-1.393c1.761.946 3.743 1.442 5.8 1.442h.001C18.618 23.239 24 17.856 24 11.208 24 4.56.284 0 12.031 0zm0 1.933c5.597 0 10.147 4.55 10.147 10.147 0 5.597-4.55 10.147-10.147 10.147h-.001c-1.85 0-3.66-.481-5.253-1.39l-.377-.215-3.9.1.58-10.147-10.147zM8.324 6.786c-.347 0-.909.13-1.385.65-.476.52-1.819 1.775-1.819 4.332 0 2.556 1.862 5.024 2.122 5.37.26.347 3.66 5.587 8.868 7.84.588.246 1.047.393 1.41.503.59.187 1.127.16 1.551.097.472-.07 1.455-.595 1.66-1.17.205-.575.205-1.066.144-1.17-.06-.104-.233-.165-.494-.294-.26-.13-1.538-.76-1.776-.847-.238-.087-.411-.13-.585.13-.174.26-.672.847-.823 1.02-.152.174-.304.195-.563.065-.26-.13-1.096-.404-2.088-1.29a7.66 7.66 0 01-1.449-1.816c-.152-.26-.016-.401.114-.53.117-.116.26-.303.39-.455.13-.152.173-.26.26-.434.087-.174.043-.325-.022-.455-.065-.13-.585-1.411-.802-1.933-.21-.505-.424-.437-.585-.445h-.5z"/></svg>
                FALAR NO WHATSAPP
            </a>
        </div>
        
        <div class="mt-12 animate-bounce">
            <svg class="w-6 h-6 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
        </div>
    </section>

    <!-- Sobre Nós Section -->
    <section class="py-20 bg-navy text-center px-4">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-3xl font-bold font-display tracking-widest uppercase mb-6 text-ivory">Sobre Nós</h2>
            <p class="text-lg leading-relaxed text-slate-300 mb-8 max-w-2xl mx-auto font-serif whitespace-pre-line">
                <%= listing.mini_bio || 'Especialistas em remoção e assistência veicular em ' + city.name + '. Trabalhamos com rigor técnico, equipamentos modernos e atendimento rápido para garantir a melhor solução em momentos críticos.' %>
            </p>
            <div class="flex justify-center gap-4">
                <a href="#" class="w-10 h-10 rounded-full border border-slate-custom flex items-center justify-center text-slate-400 hover:text-gold hover:border-gold transition-colors"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" /></svg></a>
                <a href="#" class="w-10 h-10 rounded-full border border-slate-custom flex items-center justify-center text-slate-400 hover:text-gold hover:border-gold transition-colors"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg></a>
                <a href="#" class="w-10 h-10 rounded-full border border-slate-custom flex items-center justify-center text-slate-400 hover:text-gold hover:border-gold transition-colors"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg></a>
            </div>
        </div>
    </section>

    <!-- Serviços Section -->
    <section class="py-20 bg-[#111111] px-4">
        <div class="max-w-5xl mx-auto">
            <h2 class="text-3xl font-bold tracking-widest text-center uppercase mb-12 text-white">Nossos Serviços</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Render dynamic tags from database -->
                <% 
                const genericServices = [
                    { t: "Socorro 24h", d: "Atendimento emergencial a qualquer hora.", i: "M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10 M14 9h4l3 3v4h-3M18 12h-2M15 9l-2-2" },
                    { t: "Abertura de Veículos", d: "Desbloqueio profissional sem danificar seu veículo.", i: "M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" },
                    { t: "Resposta Rápida", d: "Chegamos ao local em tempo recorde.", i: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" }
                ];
                
                let loopArray = (listing.tags && listing.tags.length > 0) ? listing.tags.map(t => ({ 
                    t: t.name, 
                    d: t.description || "Serviço profissional garantido.", 
                    i: t.icon_svg || "M5 13l4 4L19 7" 
                })) : genericServices;
                
                loopArray.forEach(svc => { 
                %>
                    <div class="bg-steel border border-slate-custom rounded-xl p-8 hover:border-gold transition-colors flex flex-col items-center text-center shadow-lg">
                        <svg class="w-10 h-10 text-gold mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= svc.i %>"></path>
                        </svg>
                        <h3 class="text-xl font-bold font-display text-ivory mb-2"><%= svc.t %></h3>
                        <p class="text-sm text-slate-400 leading-relaxed font-serif"><%= svc.d %></p>
                    </div>
                <% }) %>
            </div>
            
            <div class="mt-12 flex justify-center">
                <span class="inline-block px-4 py-2 bg-navy border border-slate-custom rounded-full text-slate-400 text-sm font-bold tracking-wide">
                    Território de Atuação: <%= city.name %> e Cidades Vizinhas
                </span>
            </div>
        </div>
    </section>

    <!-- Galeria Full -->
    <% if(listing.images && listing.images.length > 0) { %>
        <section class="py-20 bg-navy px-4 border-t border-slate-custom">
            <div class="max-w-6xl mx-auto">
                <h2 class="text-3xl font-bold font-display tracking-widest text-center uppercase mb-12 text-ivory">Galeria de <span class="text-gold">Fotos</span></h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <% listing.images.forEach(img => { %>
                        <div class="rounded-2xl overflow-hidden bg-steel border border-slate-custom aspect-w-4 aspect-h-5 shadow-2xl">
                            <img src="<%= img.image_url %>" alt="Serviço do Guincho <%= listing.company_name %>" class="w-full h-full object-cover transition-transform hover:scale-105 duration-500">
                        </div>
                    <% }) %>
                </div>
            </div>
        </section>
    <% } %>

    <!-- Minimal Footer -->
    <footer class="py-12 bg-[#050b14] border-t border-steel text-center px-4 font-sans">
        <div class="max-w-3xl mx-auto">
            <p class="text-slate-500 text-sm leading-relaxed mb-6 font-medium">
                O AutoGuincho facilita o encontro entre clientes e prestadores. A responsabilidade técnica e civil pelos serviços é exclusiva do prestador cadastrado.
            </p>
            <p class="text-slate-600 text-xs tracking-widest uppercase">
                <a href="https://corpodigital.com.br" target="_blank" rel="noopener noreferrer" class="hover:text-gold transition-colors">Desenvolvido pela Unidade de Performance da Corpo Digital</a>
            </p>
        </div>
    </footer>

    <!-- Analytics Tracker script para não perder a métrica de click nos links diretos! -->
    <script>
        function trackClick(eventType, linkId, path, partnerId) {
            fetch('/api/analytics/event', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    event_type: eventType,
                    page_path: path,
                    button_id: linkId,
                    partner_id: partnerId
                })
            }).catch(e => console.error("Analytics erro:", e));
        }
    </script>
</body>
</html>
