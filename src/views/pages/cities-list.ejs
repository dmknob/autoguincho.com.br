<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 flex-grow">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-slate-400">
        <ol class="list-none p-0 inline-flex">
            <li class="flex items-center">
                <a href="/estados" class="hover:text-gold transition-colors">Estados Atendidos</a>
                <svg class="w-3 h-3 mx-2 fill-current" viewBox="0 0 32 32"><path d="M22 16L12 26l-1.4-1.4 8.6-8.6-8.6-8.6L12 6z"></path></svg>
            </li>
            <li class="flex items-center">
                <span class="text-ivory font-medium"><%= state.name %></span>
            </li>
        </ol>
    </nav>

    <div class="mb-8 border-b border-slate-custom pb-5">
        <h1 class="text-3xl md:text-4xl font-extrabold font-display text-ivory">
            Cidades em <span class="text-gold"><%= state.name %> (<%= state.uf %>)</span>
        </h1>
        <p class="mt-2 text-slate-300 text-lg">
            Selecione uma cidade para encontrar guinchos e profissionais de socorro 24 horas.
        </p>
    </div>

    <% if(cities.length === 0) { %>
        <div class="text-center py-20 bg-steel rounded-2xl shadow-lg border border-slate-custom">
            <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            </svg>
            <h3 class="mt-4 text-lg font-medium text-ivory">Nenhuma cidade cadastrada ainda</h3>
            <p class="mt-1 text-slate-400">Em breve teremos profissionais nesta região para o estado de <%= state.name %>.</p>
        </div>
    <% } else { %>
        <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
            <% cities.forEach(function(city) { %>
                <a href="/<%= state.uf.toLowerCase() %>/<%= city.slug %>" class="bg-steel rounded-xl shadow-lg border border-slate-custom hover:border-gold hover:shadow-gold/10 p-5 flex items-center justify-between transition-all group hover:-translate-y-0.5">
                    <span class="text-lg font-semibold text-ivory group-hover:text-gold transition-colors"><%= city.name %></span>
                    <span class="bg-navy text-gold py-1 px-3 rounded-full text-xs font-bold border border-slate-custom group-hover:border-gold transition-colors">
                        <%= city.provider_count %> prestadores
                    </span>
                </a>
            <% }); %>
        </div>
    <% } %>
</main>

<%- include('../partials/footer') %>
