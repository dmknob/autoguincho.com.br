<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <%- include('../partials/head') %>

        <!-- SEO: JSON-LD @graph (Breadcrumbs + LocalBusiness) -->
        <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Início", "item": "<%= BASE_URL %>" },
            { "@type": "ListItem", "position": 2, "name": "<%= category.name %>", "item": "<%= BASE_URL %>/#search" },
            { "@type": "ListItem", "position": 3, "name": "<%= city.name %>", "item": "<%= BASE_URL %><%= path %>" }
          ]
        },
        {
          "@type": "ItemList",
          "name": "<%= category.name %> em <%= city.name %>",
          "description": "Lista de profissionais de <%= category.name %> em <%= city.name %>, <%= city.state_uf %>.",
          "itemListElement": [
            <% listings.forEach(function(l, index) { %>
            {
              "@type": "ListItem",
              "position": <%= index + 1 %>,
              "url": "<%= BASE_URL %>/perfil/<%= l.slug %>",
              "name": "<%= l.company_name %>"
            }<%= index < listings.length - 1 ? ',' : '' %>
            <% }); %>
          ]
        }
      ]
    }
    </script>
</head>

<body class="bg-navy font-sans text-ivory min-h-screen flex flex-col">

    <%- include('../partials/header') %>

        <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 flex-grow w-full">
            <div class="mb-8 border-b border-gray-800 pb-5">
                <h1 class="text-3xl md:text-5xl font-extrabold text-ivory tracking-tight">
                    <%= category.name %> em <span class="text-gold">
                            <%= city.name %>
                        </span> - <%= city.state_uf %>
                </h1>
                <p class="mt-2 text-gray-400 text-lg">
                    Prestadores ativos na sua região. Ligue e negocie diretamente.
                </p>
            </div>

            <% if (listings.length===0) { %>
                <div class="text-center py-20 bg-gray-900 rounded-2xl shadow-lg border border-gray-800">
                    <h3 class="mt-2 text-xl font-medium text-ivory">Nenhum profissional listado nesta cidade ainda.</h3>
                    <p class="mt-1 text-sm text-gray-400">Seja o primeiro parceiro nesta região!</p>
                    <a href="https://wa.me/5551993668728"
                        class="mt-6 inline-block bg-gold text-black font-bold px-6 py-3 rounded-xl hover:scale-105 transition-transform">Quero
                        me cadastrar</a>
                </div>
                <% } else { %>
                    <div class="flex flex-wrap gap-6" id="cards-container">
                        <% listings.forEach(function(l) { %>
                            <% let tierWeight=3; if(l.plan_level==='elite' ) tierWeight=1; if(l.plan_level==='partner' )
                                tierWeight=2; %>

                                <div class="flex-1 min-w-[280px] bg-gray-900 rounded-2xl shadow-lg border <%= l.plan_level === 'elite' ? 'border-gold shadow-gold/10' : 'border-gray-800' %> overflow-hidden flex flex-col"
                                    data-tier="<%= tierWeight %>" data-salt="<%= Math.random() %>">

                                    <% if(l.plan_level==='elite' ) { %>
                                        <div
                                            class="bg-gold text-black text-xs font-bold uppercase tracking-wider text-center py-1">
                                            Exposição Elite</div>
                                        <% } %>

                                            <a href="/perfil/<%= l.slug %>" class="flex-grow flex flex-col p-5">
                                                <h2
                                                    class="text-xl font-bold text-ivory hover:text-gold transition-colors break-words">
                                                    <%= l.company_name %>
                                                </h2>
                                            </a>

                                            <div class="px-5 pb-5 mt-auto flex flex-col gap-2">
                                                <% if (l.whatsapp_number) { %>
                                                    <a href="/r/wa/<%= l.id %>"
                                                        target="_blank"
                                                        class="flex justify-center items-center py-3 px-4 rounded-xl font-bold text-white bg-green-600 hover:bg-green-700 transition shadow-lg shadow-green-900/20">
                                                        Chamar no WhatsApp
                                                    </a>
                                                <% } %>

                                                <% if (l.call_number) { %>
                                                    <a href="/r/call/<%= l.id %>"
                                                        class="flex justify-center items-center py-3 px-4 rounded-xl font-bold text-white bg-slate-800 hover:bg-slate-700 transition border border-slate-700">
                                                        Ligar Agora
                                                    </a>
                                                <% } %>
                                            </div>
                                </div>
                                <% }); %>
                    </div>

                    <!-- Links de Utilidade e Curadoria -->
                    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-left">
                        <div>
                            <p class="text-gray-400 font-medium">Informação incorreta ou não foi atendido?</p>
                            <a href="https://wa.me/<%= WHATSAPP_CONTACT %>?text=Oi.%20Vi%20os%20resultados%20de%20<%= category.name %>%20em%20<%= city.name %>%20no%20Auto%20Guincho%20e%20os%20dados%20estão%20desatualizados." 
                               target="_blank" class="text-gold hover:underline text-sm font-bold mt-1 inline-block">
                                Avise-nos agora pelo WhatsApp
                            </a>
                        </div>
                        <div class="md:text-right">
                            <p class="text-gray-400 font-medium font-serif italic text-lg">Esta empresa é sua?</p>
                            <a href="/seja-parceiro" class="text-white hover:underline text-sm font-black bg-white/5 px-4 py-2 rounded-lg border border-white/10 mt-2 inline-block">
                                Atualize e valide seus dados GRATUITAMENTE
                            </a>
                        </div>
                    </div>
                    <% } %>
        </main>

        <%- include('../partials/footer') %>

</body>

</html>