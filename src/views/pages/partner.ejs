<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <%- include('../partials/head') %>

        <!-- SEO: JSON-LD @graph (Breadcrumbs + ProfessionalService) -->
        <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Início", "item": "<%= BASE_URL %>" },
            { "@type": "ListItem", "position": 2, "name": "Perfis", "item": "<%= BASE_URL %>" },
            { "@type": "ListItem", "position": 3, "name": "<%= partner.company_name %>", "item": "<%= BASE_URL %><%= path %>" }
          ]
        },
        {
          "@type": "ProfessionalService",
          "name": "<%= partner.company_name %>",
          "image": "<%= locals.og_image_url || (BASE_URL + '/images/og-default.webp') %>",
          "url": "<%= BASE_URL %><%= path %>",
          "telephone": "<%= partner.whatsapp_number %>",
          "priceRange": "$$",
          "provider": { "@type": "Organization", "name": "Auto Guincho", "url": "<%= BASE_URL %>" }
        }
      ]
    }
    </script>
    <meta property="og:image" content="<%= locals.og_image_url || (BASE_URL + '/images/og-default.webp') %>">
</head>

<body class="bg-navy font-sans text-ivory min-h-screen flex flex-col">

    <%- include('../partials/header') %>

        <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 flex-grow w-full">

            <!-- Hero Box do Perfil -->
            <div
                class="bg-gray-900 border <%= partner.plan_level === 'elite' ? 'border-gold shadow-gold/20 shadow-xl' : 'border-gray-800' %> rounded-3xl overflow-hidden">

                <!-- Placeholder Capa / Logo Area -->
                <div class="relative w-full overflow-hidden flex items-center justify-center p-4 <%= locals.cover_url ? 'h-32 md:h-48 bg-cover bg-center' : 'h-28 bg-gray-800' %>"
                     <%- locals.cover_url ? `style="background-image: url('${locals.cover_url}');"` : '' %>>
                    <div class="absolute inset-0 <%= locals.cover_url ? 'bg-black/50 backdrop-blur-[2px]' : 'opacity-20' %>"
                        <%- !locals.cover_url ? `style="background-image: radial-gradient(#d4af37 1px, transparent 1px); background-size: 16px 16px;"` : '' %>>
                    </div>
                    <% if (locals.logo_url) { %>
                        <img src="<%= locals.logo_url %>" alt="Logotipo <%= partner.company_name %>" class="relative z-10 max-h-full max-w-full object-contain filter drop-shadow-lg" fetchpriority="high" loading="eager">
                    <% } else { %>
                        <div class="relative z-10 text-gold/30 text-5xl font-black uppercase tracking-tighter">
                            <%= partner.company_name.split(' ').map(n => n[0]).join('').slice(0,3) %>
                        </div>
                    <% } %>
                </div>

                <div class="p-8">
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                        <h1 id="partner-title" class="text-3xl md:text-5xl font-extrabold text-ivory tracking-tight break-words">
                            <%= partner.company_name %>
                        </h1>
                        
                        <% if (locals.servedCategories && servedCategories.length > 0) { %>
                            <div class="flex flex-wrap gap-2 mt-2">
                                <% servedCategories.forEach(cat => { %>
                                    <span class="px-3 py-1 bg-gold/20 text-gold text-xs font-bold uppercase tracking-widest rounded-full border border-gold/30">
                                        <%= cat.name %>
                                    </span>
                                <% }) %>
                            </div>
                        <% } %>
                        
                        <div class="flex flex-wrap items-center gap-3">
                            <% if (partner.maps_link && (plans[partner.plan_level] || plans.basic).show_maps) { %>
                                <a href="<%= partner.maps_link %>" target="_blank" class="inline-flex items-center gap-1 text-gold hover:text-white transition text-sm font-bold mt-1 md:mt-0 underline underline-offset-4 decoration-gold/30">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                                    </svg>
                                    Ver no Mapa
                                </a>
                            <% } %>
                            
                            <% 
                                let topSocials = {};
                                try { topSocials = JSON.parse(partner.social_links || '{}'); } catch(e) {}
                                if (Object.keys(topSocials).length > 0 && (plans[partner.plan_level] || plans.basic).show_social) {
                            %>
                                <% if (topSocials.instagram) { %>
                                    <a href="<%= topSocials.instagram %>" target="_blank" class="px-3 py-1 border border-gray-700 rounded-full text-gray-300 bg-gray-800 hover:bg-gold hover:text-black hover:border-gold transition font-bold text-xs tracking-wide shadow-sm">Insta</a>
                                <% } %>
                                <% if (topSocials.facebook) { %>
                                    <a href="<%= topSocials.facebook %>" target="_blank" class="px-3 py-1 border border-gray-700 rounded-full text-gray-300 bg-gray-800 hover:bg-gold hover:text-black hover:border-gold transition font-bold text-xs tracking-wide shadow-sm">Face</a>
                                <% } %>
                                <% if (topSocials.website) { %>
                                    <a href="<%= topSocials.website %>" target="_blank" class="px-3 py-1 border border-gray-700 rounded-full text-gray-300 bg-gray-800 hover:bg-gold hover:text-black hover:border-gold transition font-bold text-xs tracking-wide shadow-sm">Site</a>
                                <% } %>
                            <% } %>
                        </div>
                    </div>

                    <div class="mt-4 flex flex-wrap gap-2">
                        <% if(partner.plan_level === 'elite' || partner.plan_level === 'intermediate' || partner.plan_level === 'partner') { %>
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-black bg-gold text-black uppercase tracking-widest">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                                    <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
                                </svg>
                                <%= partner.plan_level === 'elite' ? 'Parceiro em Destaque' : 'Parceiro Verificado' %>
                            </span>
                        <% } %>

                        <% 
                           let partnerBadges = [];
                           try { partnerBadges = partner.badges ? JSON.parse(partner.badges) : []; } catch(e) {}
                           partnerBadges.forEach(badge => { 
                        %>
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-white/10 text-white border border-white/20 whitespace-nowrap">
                                <%= badge %>
                            </span>
                        <% }); %>
                    </div>


                    <!-- Serviços Prestados Section -->
                    <% if (locals.servedCategories && servedCategories.length > 0) { %>
                        <div class="mt-6">
                            <h2 class="text-xs font-bold text-[#a09080] uppercase tracking-widest mb-3">Serviços Prestados</h2>
                            <div class="flex flex-wrap gap-2">
                                <% servedCategories.forEach(cat => { %>
                                    <a href="<%= BASE_URL %>/<%= cat.slug %>" class="px-3 py-1 bg-white/5 border border-gold/30 rounded-full text-xs font-bold text-ivory hover:bg-gold/10 hover:border-gold transition">
                                        <%= cat.name %>
                                    </a>
                                <% }) %>
                            </div>
                        </div>
                    <% } %>

                    <!-- Cidades Atendidas Movidas para Parte Inferior -->

                    <div class="mt-8 flex flex-col gap-4 border-t border-gray-800 pt-8">
                        <%
                            let rawTelP = partner.whatsapp_number || partner.call_number || '';
                            let maskedTelP = 'Ver Contato';
                            let fullTelP = '';
                            // Parser robusto: aceita 55+DDD+num (12-13 dig) ou DDD+num (10-11 dig)
                            let strippedP = rawTelP.replace(/\D/g, '');
                            let dddP = '', localNumP = '';
                            if (strippedP.startsWith('55') && strippedP.length >= 12) {
                                dddP = strippedP.substring(2, 4);
                                localNumP = strippedP.substring(4);
                            } else if (strippedP.length >= 10 && strippedP.length <= 11) {
                                dddP = strippedP.substring(0, 2);
                                localNumP = strippedP.substring(2);
                            }
                            if (dddP && localNumP) {
                                let visibleP = localNumP.length - 4;
                                maskedTelP = `(${dddP}) ${localNumP.substring(0, visibleP)}-****`;
                                fullTelP = `(${dddP}) ${localNumP.substring(0, visibleP)}-${localNumP.substring(visibleP)}`;
                            }
                        %>

                        <!-- Botão inicial ofuscado -->
                        <button type="button" onclick="revealContact('<%= partner.id %>')" id="btn-reveal-<%= partner.id %>"
                            data-tel="<%= fullTelP %>"
                            class="w-full flex flex-col justify-center items-center py-4 px-6 rounded-xl font-bold text-white bg-slate-800 hover:bg-slate-700 transition border border-slate-600 cursor-pointer shadow-lg">
                            <span class="text-sm font-normal text-slate-400 mb-1">Contato Direto</span>
                            <span class="text-2xl tracking-widest text-gold"><%= maskedTelP %></span>
                            <span class="text-xs text-slate-400 mt-1 uppercase tracking-wider">▼ Clique para revelar</span>
                        </button>

                        <!-- Contatos reais revelados -->
                        <div id="real-contacts-<%= partner.id %>" class="hidden flex-col md:flex-row gap-4">
                            <p id="full-tel-<%= partner.id %>" class="w-full text-center text-gold font-bold text-2xl tracking-widest py-2"></p>
                            <% if (partner.whatsapp_number) { %>
                                <a href="https://wa.me/<%= partner.whatsapp_number.replace(/\D/g, '') %>?text=Olá,%20vi%20seu%20contato%20no%20Auto%20Guincho." 
                                   target="_blank" rel="nofollow noreferrer"
                                   onclick="trackAction('whatsapp', '<%= partner.id %>')"
                                   class="flex-1 flex justify-center items-center py-4 px-6 rounded-xl font-bold text-lg text-white bg-green-600 hover:bg-green-700 transition shadow-[0_0_15px_rgba(22,163,74,0.4)]">
                                    Chamar no WhatsApp
                                </a>
                            <% } %>
                            <% if (partner.call_number) { %>
                                <a href="tel:<%= partner.call_number.replace(/\D/g, '') %>" 
                                   rel="nofollow noreferrer"
                                   onclick="trackAction('call', '<%= partner.id %>')"
                                   class="flex-1 flex justify-center items-center py-4 px-6 rounded-xl font-bold text-lg text-white bg-slate-800 hover:bg-slate-700 transition border border-slate-700">
                                    Ligar Agora
                                </a>
                            <% } %>
                        </div>

                        <!-- Disclaimer Jurídico -->
                        <p class="text-xs text-[#a09080] text-center mt-2">
                            O Auto Guincho é uma plataforma de divulgação. Não certificamos nem atestamos a idoneidade dos prestadores anunciados.
                        </p>
                    </div>

            </div> <!-- Fim de p-8 -->
            </div> <!-- Fim do Box Principal (Borda Dourada) -->

            <!-- Conteúdo Rico -->
            <div class="mt-8 bg-black/30 border border-gray-800 rounded-2xl p-8 text-gray-300 markdown-body">
                <% if (locals.html_text) { %>
                    <%- html_text %>
                <% } else { %>
                    <p>Página oficial do parceiro <%= partner.company_name %> no ecossistema Auto Guincho. Profissional qualificado para atendimento emergencial.</p>
                <% } %>
            </div>

            <%
                // A variável galleryImages já vem mesclada (DB+FileSystem) e com limite aplicado pelo controller SSR/SSG
                const visibleImages = locals.galleryImages || [];
            %>
            <% if (visibleImages.length > 0) { %>
            <!-- Galeria de Fotos -->
            <div class="mt-8">
                <h2 class="text-xs font-bold text-[#a09080] uppercase tracking-widest mb-4">Galeria de Fotos</h2>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                    <% visibleImages.forEach(function(imgUrl, idx) { %>
                        <div class="aspect-video bg-gray-900 rounded-xl overflow-hidden cursor-pointer group border border-gray-800 hover:border-gold/40 transition"
                             onclick="openLightbox('<%= imgUrl %>', '<%= partner.company_name %>')">
                            <img src="<%= imgUrl %>" alt="Foto <%= idx + 1 %> de <%= partner.company_name %>"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                 loading="lazy">
                        </div>
                    <% }); %>
                </div>
            </div>

            <!-- Lightbox Modal -->
            <div id="gallery-lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 backdrop-blur-sm"
                 onclick="closeLightbox()">
                <button class="absolute top-4 right-6 text-white text-4xl font-thin leading-none hover:text-gold transition" onclick="closeLightbox()">&#x2715;</button>
                <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[85vh] object-contain rounded-xl shadow-2xl">
                <p id="lightbox-caption" class="absolute bottom-4 text-gray-400 text-sm"></p>
            </div>
            <% } %>

            <!-- Cidades Atendidas Section (Moved to Bottom) -->
            <% if (locals.servedCities && servedCities.length > 0) { %>
                <div class="mt-8 bg-gray-900 border border-gray-800 rounded-2xl p-8">
                    <h2 class="text-xs font-bold text-[#a09080] uppercase tracking-widest mb-3">Cidades de Atuação</h2>
                    <div class="flex flex-wrap gap-2">
                        <% servedCities.slice(0, 20).forEach(city => { %>
                            <a href="<%= BASE_URL %>/<%- (locals.servedCategories && servedCategories[0]) ? servedCategories[0].slug : 'guincho-plataforma' %>/<%= city.state_uf.toLowerCase() %>/<%= city.slug %>" class="px-3 py-1 bg-white/5 border border-white/10 rounded-full text-xs text-gray-400 hover:border-gold/50 hover:text-gold transition">
                                <%= city.name %> - <%= city.state_uf %>
                            </a>
                        <% }) %>
                    </div>
                </div>
            <% } %>

            <!-- Links de Utilidade e Curadoria -->
            <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-left">
                <div>
                    <p class="text-gray-400 font-medium">Informação incorreta ou não foi atendido?</p>
                    <a href="https://wa.me/<%= WHATSAPP_CONTACT %>?text=Oi.%20Vi%20o%20perfil%20de%20<%= partner.slug %>%20no%20Auto%20Guincho%20e%20tive%20problemas%20com%20o%20contato." 
                       target="_blank" class="text-gold hover:underline text-sm font-bold mt-1 inline-block">
                        Avise nosso suporte pelo WhatsApp
                    </a>
                </div>
                <div class="md:text-right">
                    <p class="text-gray-400 font-medium font-serif italic text-lg">Esta empresa é sua?</p>
                    <a href="/seja-parceiro" class="text-white hover:underline text-sm font-black bg-white/5 px-4 py-2 rounded-lg border border-white/10 mt-2 inline-block">
                        Atualize e valide seus dados GRATUITAMENTE
                    </a>
                </div>
            </div>

        </main>

        <!-- Sticky Mobile CTA -->
        <div id="sticky-cta-<%= partner.id %>" class="fixed bottom-0 left-0 w-full bg-gray-900/95 backdrop-blur-md border-t border-gray-800 p-4 z-50 md:hidden flex gap-3 transition-transform duration-300 ease-in-out transform translate-y-full opacity-0 shadow-[0_-10px_20px_rgba(0,0,0,0.5)]">
            <% if (partner.whatsapp_number) { %>
                <a href="https://wa.me/<%= partner.whatsapp_number.replace(/\D/g, '') %>?text=Olá,%20vi%20seu%20contato%20no%20Auto%20Guincho." 
                   target="_blank" rel="nofollow noreferrer" 
                   onclick="trackAction('whatsapp', '<%= partner.id %>')"
                   class="flex-1 flex justify-center items-center py-3 rounded-xl font-bold text-white bg-green-600 shadow-lg text-sm gap-2">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    WhatsApp
                </a>
            <% } %>
            <% if (partner.call_number) { %>
                <a href="tel:<%= partner.call_number.replace(/\D/g, '') %>" 
                   rel="nofollow noreferrer" 
                   onclick="trackAction('call', '<%= partner.id %>')"
                   class="flex-1 flex justify-center items-center py-3 rounded-xl font-bold text-white bg-slate-800 border border-slate-700 text-sm">
                    Ligar
                </a>
            <% } %>
        </div>

        <%- include('../partials/footer') %>

    <script>
        // ── Lightbox da Galeria ──────────────────────────
        function openLightbox(src, caption) {
            var lb = document.getElementById('gallery-lightbox');
            document.getElementById('lightbox-img').src = src;
            document.getElementById('lightbox-caption').textContent = caption;
            lb.classList.remove('hidden');
            lb.classList.add('flex');
            document.body.style.overflow = 'hidden';
        }
        function closeLightbox() {
            var lb = document.getElementById('gallery-lightbox');
            lb.classList.add('hidden');
            lb.classList.remove('flex');
            document.getElementById('lightbox-img').src = '';
            document.body.style.overflow = '';
        }
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeLightbox();
        });
    </script>

    <script>
        // --- Personalização Contextual (?ref=...) ---
        window.addEventListener('DOMContentLoaded', () => {
            const params = new URLSearchParams(window.location.search);
            const ref = params.get('ref');
            if (ref) {
                const titleEl = document.getElementById('partner-title');
                // Busca o nome legível da categoria se houver no JSON de categorias (simplificado aqui)
                const catName = ref.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
                if (titleEl) {
                    const originalText = titleEl.textContent.trim();
                    titleEl.innerHTML = `<span class="text-gold block text-sm uppercase tracking-widest mb-2">Especialista em ${catName}</span> ${originalText}`;
                }
            }
        });

        // --- Tracking Resiliente (sendBeacon + fallback) ---
        function sendTracking(data) {
            const url = '/api/system/interaction';
            const body = JSON.stringify({
                ...data,
                // Captura UTMs da URL se presentes para atribuição de sessão no lead
                utm_source: new URLSearchParams(window.location.search).get('utm_source'),
                utm_medium: new URLSearchParams(window.location.search).get('utm_medium'),
                utm_campaign: new URLSearchParams(window.location.search).get('utm_campaign')
            });

            if (navigator.sendBeacon) {
                navigator.sendBeacon(url, new Blob([body], { type: 'application/json' }));
            } else {
                fetch(url, { 
                    method: 'POST', 
                    body, 
                    headers: { 'Content-Type': 'application/json' },
                    keepalive: true 
                }).catch(() => {});
            }
        }

        function trackAction(label, id) {
            sendTracking({
                event_type: 'cta_click',
                event_label: label,
                page_path: window.location.pathname,
                entity_type: 'listing',
                entity_id: parseInt(id)
            });
        }

        function revealContact(id, trackLead) {
            var btn = document.getElementById('btn-reveal-' + id);
            var box = document.getElementById('real-contacts-' + id);
            var telEl = document.getElementById('full-tel-' + id);
            var stickyCta = document.getElementById('sticky-cta-' + id);

            if (btn) {
                if (telEl) telEl.textContent = btn.dataset.tel || '';
                btn.style.display = 'none';
            }
            if (box) {
                box.classList.remove('hidden');
                box.classList.add('flex');
            }
            if (stickyCta) {
                stickyCta.classList.remove('translate-y-full', 'opacity-0');
            }

            if (trackLead !== false && !sessionStorage.getItem('revealed_' + id)) {
                sessionStorage.setItem('revealed_' + id, '1');
                sendTracking({
                    event_type: 'cta_click',
                    event_label: 'reveal',
                    page_path: window.location.pathname,
                    entity_type: 'listing',
                    entity_id: parseInt(id)
                });
            }
        }

        // Restaura estado ao recarregar a página (F5)
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('[id^="btn-reveal-"]').forEach(function(btn) {
                var id = btn.id.replace('btn-reveal-', '');
                if (sessionStorage.getItem('revealed_' + id)) {
                    revealContact(id, false);
                }
            });

            // Page View Tracking
            setTimeout(() => {
                sendTracking({ 
                    event_type: 'page_view', 
                    page_path: window.location.pathname, 
                    entity_type: 'listing', 
                    entity_id: <%= partner.id %> 
                });
            }, 500);
        });
    </script>

</body>
</html>