<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="flex-grow max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
    <div class="bg-navy rounded-3xl p-8 md:p-12 shadow-2xl border border-slate-custom">
        <h1 class="text-3xl font-extrabold font-display text-ivory tracking-tight mb-8">Validação de Analytics e Interações</h1>
        <p class="text-slate-400 mb-8 font-serif italic text-lg pb-6 border-b border-steel">Visualização provisória (MVP) de interações e métricas gravadas no DataWarehouse do AutoGuincho.</p>
        
        <% if(stats && stats.length > 0) { %>
            <!-- Mobile View (Cards) -->
            <div class="grid gap-4 md:hidden">
                <% stats.forEach((s, idx) => { %>
                    <div class="bg-steel/50 rounded-xl p-5 border border-slate-custom shadow-sm flex flex-col gap-3">
                        <div class="flex justify-between items-start">
                            <span class="font-bold text-ivory text-lg"><%= s.company_name %></span>
                            <span class="inline-flex w-8 h-8 items-center justify-center rounded-full bg-gold text-navy font-black shadow-md border border-[#b0923d] text-sm"><%= s.clicks %></span>
                        </div>
                        <div>
                            <span class="px-2.5 py-1 rounded-md bg-navy border border-slate-custom text-xs uppercase tracking-wider text-slate-300"><%= s.event_label %></span>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Desktop View (Table) -->
            <div class="hidden md:block overflow-x-auto rounded-xl border border-steel shadow-lg">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-steel text-gold font-display uppercase tracking-widest text-xs lg:text-sm border-b border-slate-custom">
                            <th class="p-5 rounded-tl-xl whitespace-nowrap">Parceiro (Empresa)</th>
                            <th class="p-5 whitespace-nowrap">Evento Captado</th>
                            <th class="p-5 rounded-tr-xl text-center">Cliques</th>
                        </tr>
                    </thead>
                    <tbody class="text-slate-300 bg-[#0a1628]/50">
                        <% stats.forEach((s, idx) => { %>
                            <tr class="border-b border-steel last:border-b-0 hover:bg-steel/50 transition-colors">
                                <td class="p-5 font-bold text-ivory"><%= s.company_name %></td>
                                <td class="p-5">
                                    <span class="px-3 py-1.5 rounded-md bg-navy border border-slate-custom text-xs uppercase tracking-wider text-slate-300 shadow-sm">
                                        <%= s.event_label %>
                                    </span>
                                </td>
                                <td class="p-5 text-center">
                                    <span class="inline-flex w-10 h-10 items-center justify-center rounded-full bg-gold text-navy font-black shadow-md border border-[#b0923d]">
                                        <%= s.clicks %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center py-16 bg-steel rounded-2xl border border-slate-custom shadow-inner">
                 <svg class="mx-auto h-12 w-12 text-slate-500 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                 </svg>
                 <p class="text-slate-400 text-lg">Nenhuma interação registrada ainda. Navegue nos perfis e chame um parceiro para os eventos preencherem esta tabela via backend tracking.</p>
            </div>
        <% } %>
        <div class="mt-8 pt-8 border-t border-steel text-center">
             <a href="/" class="text-slate-400 hover:text-gold transition-colors font-display text-sm tracking-widest uppercase">← Voltar para O Menu Inicial</a>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
